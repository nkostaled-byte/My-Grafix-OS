# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase Auth + direct reads (safe for frontend — anon key only)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Cloudflare Worker base URL — ALL business-logic actions (orders, bookings,
# uploads, invoices, PDF generation, CSV export, search, account claiming)
# go through this Worker. This app has no backend of its own for any of
# that — do not add SUPABASE_SERVICE_ROLE_KEY or RESEND_API_KEY here, they
# belong only in the Worker's own secrets, never in this frontend project.
VITE_WORKER_BASE_URL=""

